<h1><%= title %></h1> <!-- Display the heading at the top of the page -->
<% if (errors && errors.length > 0) { %>
    <div class="error-messages">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } else if (message && message.length > 0) { %>
    <div class="error-messages">
      <p><%= message %></p>
    </div>
  <% } %>
<%# **************************************
    Login Form
************************************* %>
<div class="login-container">
  <form id="loginForm" action="/account/login" method="POST">
    <label for="email">Email Address:</label>
    <input type="email" id="email" name="account_email" required>

    <label for="password">Password:</label>
    <input type="password" id="password" name="account_password" required>

    <button type="submit">Login</button>
  </form>

  <%# **************************************
      Registration Link
  ************************************* %>
  <p>Don't have an account? <a href="/account/register">Register here</a></p>
</div>
