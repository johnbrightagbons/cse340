<h1 class="account-title">Account Management</h1>

<% if (errors && errors.length > 0) { %>
    <ul class="notice">
        <% errors.forEach(error => { %>
            <li><%= error.msg %></li>
        <% }) %>
    </ul>
<% } %>

<main class="account-management">
    <div class="welcome-message">
        <h2>Welcome</h2>
       
    </div>

    <div class="account-actions">
        <a href="/account/edit" class="btn btn-primary">Edit Account Information</a>
    </div>
</main>
